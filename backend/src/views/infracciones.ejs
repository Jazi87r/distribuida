<%- include("partials/header.ejs") %>

<body>

<h1>Infracciones</h1>

<!-- CREATE INFRACTION -->
<div class="create-container">
<h2>Add Infraccion</h2>

<form id="createForm" class="create-form"> <!-- CHANGE MADE OVER HERE -->

<input type="number" name="identificacion" placeholder="identificacion" required>
<input type="date" name="fecha" required>
<input type="text" name="tipo" placeholder="Tipo" required>
<input type="number" name="vehiculo_id" placeholder="Vehiculo ID" required>


<button type="submit">Create</button>

</form>
</div>


<!-- INFRACCIONES TABLE -->
<table class="vehiculos-table">

<thead>
<tr>
<th>ID</th>
<th>Identificación</th>
<th>Fecha</th>
<th>Tipo</th>
<th>Vehiculo ID</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<!-- Example row (replace with template loop) -->

<% infracciones.forEach(infraccion => { %>

<tr>

<td><%= infraccion.id %></td>
<td><%= infraccion.identificacion %></td>
<td><%= infraccion.fecha %></td>
<td><%= infraccion.tipo %></td>
<td><%= infraccion.vehiculo_id %></td>

<td class="actions">

<!-- UPDATE -->
<form class="inline-form update-form-container" data-id="<%= infraccion.id %>">

<button type="button" class="update-btn">Update</button>

<div class="update-form hidden">

<input type="number" name="identificacion" value="<%= infraccion.identificacion %>" required>
<input type="date" name="fecha" value="<%= infraccion.fecha %>" required>
<input type="text" name="tipo" value="<%= infraccion.tipo %>" required>
<input type="number" name="vehiculo_id" value="<%= infraccion.vehiculo_id %>" required>

<button type="submit">Save</button>

</div>

</form>


<!-- DELETE -->
<button class="delete-btn" data-id="<%= infraccion.id %>">
Delete
</button>

</td>

</tr>

<% }); %>

</tbody>

</table>


<script src="/js/homepage.js"></script>

<script>
// -------- CREATE INFRACCION --------
document.getElementById("createForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const form = e.target;

  const identificacion = parseInt(form.identificacion.value);
  const fecha = form.fecha.value;
  const tipo = form.tipo.value;
  const vehiculo_id = parseInt(form.vehiculo_id.value);

  const query = `
    mutation CreateInfraccion($input: InfraccionInput!) {
      createInfraccion(input: $input) {
        id
        tipo
      }
    }
  `;

  const variables = {
    input: {
      identificacion,
      fecha,
      tipo,
      vehiculo_id
    }
  };

  try {
    const res = await fetch("/graphql", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ query, variables })
    });

    const result = await res.json();

    if (result.errors) {
      console.error("GraphQL errors:", result.errors);
      return;
    }

    window.location.reload();

  } catch (err) {
    console.error("Fetch error:", err);
  }
});


// -------- DELETE INFRACCION --------
document.querySelectorAll(".delete-btn").forEach(button => {
  button.addEventListener("click", async () => {

    const id = button.getAttribute("data-id");

    const query = `
      mutation($id: ID!) {
        deleteInfraccion(id: $id)
      }
    `;

    const variables = { id };

    try {
      const res = await fetch("/graphql", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ query, variables })
      });

      const result = await res.json();

      if (result.errors) {
        console.error("GraphQL errors:", result.errors);
        return;
      }

      window.location.reload();

    } catch (err) {
      console.error("Fetch error:", err);
    }
  });
});


// -------- UPDATE INFRACCION --------
document.querySelectorAll(".update-form-container").forEach(form => {
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const id = form.getAttribute("data-id");

    const identificacion = parseInt(form.identificacion.value);
    const fecha = form.fecha.value;
    const tipo = form.tipo.value;
    const vehiculo_id = parseInt(form.vehiculo_id.value);

    const query = `
      mutation($id: ID!, $input: InfraccionInput!) {
        updateInfraccion(id: $id, input: $input) {
          id
          tipo
        }
      }
    `;

    const variables = {
      id,
      input: {
        identificacion,
        fecha,
        tipo,
        vehiculo_id
      }
    };

    try {
      const res = await fetch("/graphql", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ query, variables })
      });

      const result = await res.json();

      if (result.errors) {
        console.error("GraphQL errors:", result.errors);
        return;
      }

      window.location.reload();

    } catch (err) {
      console.error("Fetch error:", err);
    }
  });
});
</script>

</body>

<%- include("partials/footer.ejs") %> 