<%- include("partials/header.ejs") %>

<body>

<h1>Vehiculos</h1>

<!-- CREATE VEHICLE -->
<div class="create-container">
<h2>Add Vehicle</h2>

<form id="createForm" class="create-form"> <!-- CHANGE MADE OVER HERE -->

<input type="text" name="placa" placeholder="Placa" required>
<input type="text" name="marca" placeholder="Marca" required>
<input type="number" name="matricula" placeholder="Matricula" required>
<input type="date" name="fecha_matricula" required>
<input type="text" name="tipo" placeholder="Tipo" required>
<input type="number" name="propietario_id" placeholder="Propietario ID" required>

<button type="submit">Create</button>

</form>
</div>


<!-- VEHICLE TABLE -->
<table class="vehiculos-table">

<thead>
<tr>
<th>ID</th>
<th>Placa</th>
<th>Marca</th>
<th>Matricula</th>
<th>Fecha</th>
<th>Tipo</th>
<th>Propietario</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<!-- Example row (replace with template loop) -->

<% vehiculos.forEach(vehiculo => { %>


<tr>

<td><%= vehiculo.id %></td>
<td><%= vehiculo.placa %></td>
<td><%= vehiculo.marca %></td>
<td><%= vehiculo.matricula %></td>
<td><%= vehiculo.fecha_matricula %></td>
<td><%= vehiculo.tipo %></td>
<td><%= vehiculo.propietario_id %></td>

<td class="actions">

<!-- UPDATE -->
<form class="inline-form update-form-container" data-id="<%= vehiculo.id %>">

<button type="button" class="update-btn">Update</button>

<div class="update-form hidden">

<input type="text" name="placa" value="<%= vehiculo.placa %>" required>
<input type="text" name="marca" value="<%= vehiculo.marca %>" required>
<input type="number" name="matricula" value="<%= vehiculo.matricula %>" required>
<input type="date" name="fecha_matricula" value="<%= vehiculo.fecha_matricula %>" required>
<input type="text" name="tipo" value="<%= vehiculo.tipo %>" required>
<input type="number" name="propietario_id" value="<%= vehiculo.propietario_id %>" required>

<button type="submit">Save</button>

</div>

</form>


<!-- DELETE -->

<button class="delete-btn" data-id="<%= vehiculo.id %>">
Delete
</button>

</td>

</tr>

<% }) %>


</tbody>

</table>


<script src="/js/homepage.js"></script>


<script>
document.getElementById("createForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const form = e.target;

  const placa = form.placa.value;
  const marca = form.marca.value;
  const matricula = parseInt(form.matricula.value);
  const fecha_matricula = form.fecha_matricula.value;
  const tipo = form.tipo.value;
  const propietario_id = parseInt(form.propietario_id.value);

  const query = `
    mutation CreateVehiculo($input: VehiculoInput!) {
      createVehiculo(input: $input) {
        id
        placa
      }
    }
  `;

  const variables = {
    input: {
      placa,
      marca,
      matricula,
      fecha_matricula,
      tipo,
      propietario_id
    }
  };

  try {
    const res = await fetch("/graphql", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ query, variables })
    });

    const result = await res.json();

    if (result.errors) {
      console.error("GraphQL errors:", result.errors);
      return;
    }

    console.log("GraphQL response:", result);

    window.location.reload();

  } catch (err) {
    console.error("Fetch error:", err);
  }
});

// -------- DELETE VEHICULO --------
document.querySelectorAll(".delete-btn").forEach(button => {
  button.addEventListener("click", async () => {

    const id = button.getAttribute("data-id");

    const query = `
      mutation($id: ID!) {
        deleteVehiculo(id: $id)
      }
    `;

    const variables = { id };

    try {
      const res = await fetch("/graphql", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ query, variables })
      });

      const result = await res.json();

      if (result.errors) {
        console.error("GraphQL errors:", result.errors);
        return;
      }

      console.log("Vehiculo eliminado:", result);

      window.location.reload();

    } catch (err) {
      console.error("Fetch error:", err);
    }
  });
});


// -------- UPDATE VEHICULO --------
document.querySelectorAll(".update-form-container").forEach(form => {
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const id = form.getAttribute("data-id");

    const placa = form.placa.value;
    const marca = form.marca.value;
    const matricula = parseInt(form.matricula.value);
    const fecha_matricula = form.fecha_matricula.value;
    const tipo = form.tipo.value;
    const propietario_id = parseInt(form.propietario_id.value);

    const query = `
      mutation($id: ID!, $input: VehiculoInput!) {
        updateVehiculo(id: $id, input: $input) {
          id
          placa
        }
      }
    `;

    const variables = {
      id,
      input: {
        placa,
        marca,
        matricula,
        fecha_matricula,
        tipo,
        propietario_id
      }
    };

    try {
      const res = await fetch("/graphql", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ query, variables })
      });

      const result = await res.json();

      if (result.errors) {
        console.error("GraphQL errors:", result.errors);
        return;
      }

      console.log("Vehiculo actualizado:", result);

      window.location.reload();

    } catch (err) {
      console.error("Fetch error:", err);
    }
  });
});

</script>

</body>

<%- include("partials/footer.ejs") %> 