<%- include("partials/header.ejs") %>

<body>

<h1>Vehiculos</h1>

<!-- CREATE VEHICLE -->
<div class="create-container">
<h2>Add Vehicle</h2>

<form action="/vehiculos/create" method="POST" class="create-form">

<input type="text" name="placa" placeholder="Placa" required>
<input type="text" name="marca" placeholder="Marca" required>
<input type="number" name="matricula" placeholder="Matricula" required>
<input type="date" name="fecha_matricula" required>
<input type="text" name="tipo" placeholder="Tipo" required>
<input type="number" name="propietario_id" placeholder="Propietario ID" required>

<button type="submit">Create</button>

</form>
</div>


<!-- VEHICLE TABLE -->
<table class="vehiculos-table">

<thead>
<tr>
<th>ID</th>
<th>Placa</th>
<th>Marca</th>
<th>Matricula</th>
<th>Fecha</th>
<th>Tipo</th>
<th>Propietario</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<!-- Example row (replace with template loop) -->

<tr>

<td>1</td>
<td>ABC123</td>
<td>Toyota</td>
<td>12345</td>
<td>2023-01-01</td>
<td>Carro</td>
<td>2</td>

<td class="actions">

<!-- UPDATE -->
<form action="/vehiculos/update/1" method="POST" class="inline-form">

<button type="button" class="update-btn">Update</button>

<div class="update-form hidden">

<input type="text" name="placa" value="ABC123" required>
<input type="text" name="marca" value="Toyota" required>
<input type="number" name="matricula" value="12345" required>
<input type="date" name="fecha_matricula" value="2023-01-01" required>
<input type="text" name="tipo" value="Carro" required>
<input type="number" name="propietario_id" value="2" required>

<button type="submit">Save</button>

</div>

</form>


<!-- DELETE -->
<form action="/vehiculos/delete/1" method="POST" class="inline-form">

<button type="submit" class="delete-btn">
Delete
</button>

</form>

</td>

</tr>

</tbody>

</table>


<script src="/js/homepage.js"></script>

</body>

